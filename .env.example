# Optional: set to "true" to run the app with fake data (no real ClickBank or Anthropic
# calls). Useful for local UI testing before you have all real keys.
MOCK_MODE=false
NEXT_PUBLIC_MOCK_MODE=false

# ClickBank API key with "API Order Read Role"
CLICKBANK_API_KEY_READ=

# ClickBank API key with "API Order Write Role"
CLICKBANK_API_KEY_WRITE=

# Your ClickBank vendor account nickname
CLICKBANK_VENDOR_ACCOUNT=

# Anthropic Claude API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# Strong password to protect the /admin panel
ADMIN_SECRET=
