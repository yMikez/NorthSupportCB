# ===========================================================================
# Production env — place as `.env` next to docker-compose.yml on the VPS.
# DO NOT commit this file with real values.
# ===========================================================================

# ---- Postgres (dedicated to SupportChat) ----
POSTGRES_USER=supportchat
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_RANDOM_STRING
POSTGRES_DB=supportchat

# ---- ClickBank ----
CLICKBANK_API_KEY_READ=API-...
CLICKBANK_API_KEY_WRITE=API-...
CLICKBANK_VENDORS=neurompro,burnthermo,maxvitaliz,glycopulse

# ---- Anthropic ----
ANTHROPIC_API_KEY=sk-ant-...

# ---- Admin panel password ----
ADMIN_SECRET=CHANGE_ME_TOO

# ---- Mock mode (keep false in production) ----
MOCK_MODE=false
NEXT_PUBLIC_MOCK_MODE=false
